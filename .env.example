# --- Database ---
# Local dev (docker-compose): host 5435 -> container 5432
DATABASE_URL=postgresql://onepadel:onepadel@127.0.0.1:5435/onepadel

# --- Public site URL (dipakai SEO: metadataBase, sitemap, robots, OG, link email) ---
# Prod: domain publik HTTPS (mis. https://onepadelclub.com). Dev boleh dikosongkan.
NEXT_PUBLIC_SITE_URL=http://localhost:3007

# --- Auth (better-auth) ---
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=changeme-generate-a-32-byte-secret
BETTER_AUTH_URL=http://localhost:3007

# Bootstrap admin allowlist (comma-separated). Email di sini boleh seed:admin.
ADMIN_EMAILS=admin@onepadelclub.com

# Seed admin (dipakai sekali oleh `npm run seed:admin`)
SEED_ADMIN_EMAIL=admin@onepadelclub.com
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_NAME=Admin One Padel

# --- Cloudflare R2 (upload foto/QRIS/bukti) — kosong = mock mode ke public/uploads ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=onepadelclub
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# --- Cron (expire PENDING booking) ---
CRON_SECRET=changeme-cron-secret

# --- Email notifikasi (SMTP) — OPSIONAL ---
# Konfigurasi utama via /admin/settings (disimpan di DB). ENV di bawah = fallback.
# Kosongkan semua = notifikasi email mati (app tetap jalan normal).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=One Padel Club
SMTP_FROM_EMAIL=
NOTIFY_EMAIL=
